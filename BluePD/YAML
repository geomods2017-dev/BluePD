name: BluePD

options:
  bundleIdPrefix: com.bluepd
  deploymentTarget:
    iOS: "17.0"

settings:
  base:
    PRODUCT_BUNDLE_IDENTIFIER: com.bluepd.app
    MARKETING_VERSION: 1.0
    CURRENT_PROJECT_VERSION: 1
    SWIFT_VERSION: 5.0
    CODE_SIGN_STYLE: Automatic
    DEVELOPMENT_TEAM: ""

targets:
  BluePD:
    type: application
    platform: iOS
    sources:
      - path: BluePD
    settings:
      base:
        INFOPLIST_KEY_UILaunchScreen_Generation: YES
        INFOPLIST_KEY_CFBundleDisplayName: BluePD
        INFOPLIST_KEY_NSPhotoLibraryUsageDescription: BluePD stores evidence photos on device.
        INFOPLIST_KEY_NSCameraUsageDescription: BluePD uses the camera to capture evidence photos.
    scheme:
      testTargets: []
